{
  "name": "kintone-plugin-template",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:config": "vite build --config vite.config.js --mode config",
    "build:desktop": "vite build --config vite.config.js --mode desktop",
    "build:mobile": "vite build --config vite.config.js --mode mobile",
    "copy:manifest": "cp manifest.json plugin/manifest.json",
    "build": "npm run build:config && npm run build:desktop && npm run build:mobile && npm run copy:manifest",
    "pack": "cli-kintone plugin pack --input ./plugin/manifest.json --output ./dist/plugin.zip --private-key ./private.ppk"
  },
  "dependencies": {
    "@kintone/rest-api-client": "^6.2.0",
    "i18next": "^26.2.0",
    "kintone-ui-component": "^1.25.0"
  },
  "devDependencies": {
    "@kintone/plugin-packer": "^9.1.1",
    "@kintone/plugin-uploader": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.55.9",
    "vite": "^8.0.14"
  }
}